  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "N\xE4m\xE4 s\xE4ilyneet tynnyrit sijaitsevat aluksen keulan puolella.
    Linjalaivan alimpaan ruumaan t\xE4lle paikalle sijoitettiin yleens\xE4 vesitynnyrit.
    Per\xE4n puolella oli muonatynnyreit\xE4. Vesi tuotiin maista tynnyreiss\xE4.
    Veden hankkiminen aluksen l\xE4hes 600:lle miehist\xF6n j\xE4senelle oli raskasta
    ty\xF6t\xE4."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
