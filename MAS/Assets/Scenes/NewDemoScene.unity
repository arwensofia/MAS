      m_Calls: []
  m_text: "The keel is a long structural member running down the middle of the ship\u2019s
    interior. It forms the backbone of the ship together with the keel itself. The
    ship\u2019s arches are attached in between the keel and the bilge keel."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
